[
    {
        "question": "\u9e21\u67f3\u662f\u9e21\u8eab\u4e0a\u54ea\u4e2a\u90e8\u4f4d\u554a\uff1f",
        "evaluation": [
            {
                "role": "\u5f31\u667a",
                "evaluation": "\u8fd9\u4e2a\u95ee\u9898\u672c\u8eab\u5b58\u5728\u4e00\u5b9a\u7684\u8bef\u5bfc\u6027\uff0c\u56e0\u4e3a\u5b83\u5c06\u98df\u54c1\u52a0\u5de5\u6982\u5ff5\u4e0e\u751f\u7269\u5b66\u89e3\u5256\u6982\u5ff5\u6df7\u4e3a\u4e00\u8c08\u3002  \n\n**\u5408\u7406\u6027\u5206\u6790\uff1a**  \n1. **\u8868\u9762\u5408\u7406**\uff1a\u63d0\u95ee\u8005\u53ef\u80fd\u8bef\u4ee5\u4e3a\u201c\u9e21\u67f3\u201d\u662f\u9e21\u8eab\u4e0a\u67d0\u4e2a\u7279\u5b9a\u90e8\u4f4d\u7684\u540d\u79f0\uff08\u7c7b\u4f3c\u201c\u9e21\u80f8\u201d\u201c\u9e21\u817f\u201d\uff09\uff0c\u8fd9\u6e90\u4e8e\u9910\u996e\u884c\u4e1a\u5bf9\u98df\u6750\u5f62\u6001\u7684\u4fd7\u79f0\uff08\u5982\u201c\u9c7c\u67f3\u201d\u201c\u732a\u67f3\u201d\uff09\u3002  \n2. **\u5b9e\u9645\u4e0d\u5408\u7406**\uff1a\u9e21\u67f3\u5e76\u975e\u89e3\u5256\u5b66\u90e8\u4f4d\uff0c\u800c\u662f\u5bf9\u9e21\u8089\uff08\u901a\u5e38\u53d6\u81ea\u80f8\u8089\u6216\u817f\u8089\uff09\u5207\u6761\u3001\u88f9\u7c89\u540e\u7684\u52a0\u5de5\u5f62\u6001\u3002\u7c7b\u4f3c\u201c\u85af\u6761\u201d\u4e0d\u662f\u571f\u8c46\u7684\u5929\u7136\u90e8\u4f4d\u4e00\u6837\uff0c\u5c5e\u4e8e\u4eba\u4e3a\u52a0\u5de5\u4ea7\u7269\u3002  \n\n**\u539f\u56e0\uff1a**  \n- **\u884c\u4e1a\u672f\u8bed\u8bef\u5bfc**\uff1a\u9910\u996e\u4e1a\u4e3a\u8425\u9500\u4fbf\u5229\uff0c\u5e38\u5c06\u52a0\u5de5\u540e\u7684\u5f62\u6001\u547d\u540d\u4e3a\u201cXX\u67f3\u201d\uff0c\u5bb9\u6613\u8ba9\u6d88\u8d39\u8005\u4ea7\u751f\u8bef\u89e3\u3002  \n- **\u8bed\u8a00\u6a21\u7cca\u6027**\uff1a\u4e2d\u6587\u5bf9\u98df\u6750\u7684\u547d\u540d\u6709\u65f6\u6a21\u7cca\u4e86\u5929\u7136\u90e8\u4f4d\u4e0e\u52a0\u5de5\u5f62\u6001\u7684\u754c\u9650\uff08\u5982\u201c\u9e21\u7fc5\u201d\u662f\u90e8\u4f4d\uff0c\u201c\u9e21\u7c73\u82b1\u201d\u5374\u662f\u52a0\u5de5\u54c1\uff09\u3002  \n\n**\u7ed3\u8bba**\uff1a\u95ee\u9898\u770b\u4f3c\u666e\u901a\uff0c\u4f46\u9690\u542b\u5bf9\u98df\u54c1\u52a0\u5de5\u672f\u8bed\u7684\u6df7\u6dc6\u3002\u56de\u7b54\u65f6\u9700\u533a\u5206\u201c\u751f\u7269\u5b66\u90e8\u4f4d\u201d\u548c\u201c\u52a0\u5de5\u5f62\u6001\u201d\uff0c\u907f\u514d\u4f20\u64ad\u9519\u8bef\u8ba4\u77e5\u3002"
            },
            {
                "role": "\u5929\u624d",
                "evaluation": "\u8fd9\u4e2a\u95ee\u9898\u770b\u4f3c\u5408\u7406\uff0c\u4f46\u5b9e\u9645\u4e0a\u6df7\u6dc6\u4e86\u751f\u7269\u5b66\u548c\u98df\u54c1\u52a0\u5de5\u7684\u6982\u5ff5\u3002\"\u9e21\u67f3\"\u5e76\u4e0d\u662f\u9e21\u8eab\u4e0a\u7684\u5929\u7136\u90e8\u4f4d\uff0c\u800c\u662f\u5c06\u9e21\u8089\uff08\u901a\u5e38\u662f\u80f8\u8089\u6216\u817f\u8089\uff09\u5207\u6761\u540e\u52a0\u5de5\u5236\u6210\u7684\u98df\u54c1\u5f62\u6001\u3002\u7c7b\u4f3c\"\u9c7c\u67f3\"\"\u732a\u67f3\"\u7b49\u540d\u79f0\uff0c\u90fd\u662f\u4eba\u4e3a\u52a0\u5de5\u540e\u7684\u4ea7\u54c1\u53eb\u6cd5\uff0c\u800c\u975e\u52a8\u7269\u672c\u8eab\u7684\u89e3\u5256\u7ed3\u6784\u3002\u8fd9\u79cd\u63d0\u95ee\u65b9\u5f0f\u5bb9\u6613\u8bef\u5bfc\u4eba\u4ee5\u4e3a\u9e21\u8eab\u4e0a\u5929\u7136\u5b58\u5728\"\u67f3\"\u8fd9\u79cd\u90e8\u4f4d\uff0c\u672c\u8d28\u4e0a\u662f\u4e2a\u4f2a\u547d\u9898\u3002"
            }
        ]
    },
    {
        "question": "\u6a1f\u8111\u4e38\u662f\u6211\u5403\u8fc7\u6700\u96be\u5403\u7684\u786c\u7cd6\u6709\u5947\u602a\u7684\u5473\u9053\u600e\u4e48\u8fd8\u6709\u4eba\u4e70",
        "evaluation": [
            {
                "role": "\u5f31\u667a",
                "evaluation": "\u8fd9\u4e2a\u95ee\u9898\u7684\u6838\u5fc3\u5728\u4e8e\u6df7\u6dc6\u4e86\u6a1f\u8111\u4e38\u7684\u7528\u9014\u548c\u6027\u8d28\uff0c\u56e0\u6b64**\u672c\u8d28\u4e0a\u662f\u4e00\u4e2a\u4e0d\u5408\u7406\u7684\u95ee\u9898**\u3002  \n\n### **\u4e0d\u5408\u7406\u7684\u539f\u56e0\uff1a**  \n1. **\u6a1f\u8111\u4e38\u4e0d\u662f\u98df\u54c1**\uff1a\u5b83\u662f\u9632\u866b\u5242\uff0c\u542b\u6709\u8418\u6216\u5bf9\u4e8c\u6c2f\u82ef\u7b49\u6709\u6bd2\u5316\u5b66\u7269\u8d28\uff0c\u8bef\u98df\u53ef\u80fd\u5bfc\u81f4\u4e2d\u6bd2\u751a\u81f3\u5371\u53ca\u751f\u547d\u3002  \n2. **\u95ee\u9898\u57fa\u4e8e\u9519\u8bef\u8ba4\u77e5**\uff1a\u63d0\u95ee\u8005\u5c06\u6a1f\u8111\u4e38\u8bef\u8ba4\u4e3a\u662f\u201c\u96be\u5403\u7684\u786c\u7cd6\u201d\uff0c\u8bf4\u660e\u5bf9\u7269\u54c1\u7684\u57fa\u672c\u7528\u9014\u7f3a\u4e4f\u6b63\u786e\u7406\u89e3\u3002  \n3. **\u6f5c\u5728\u8bef\u5bfc\u6027**\uff1a\u5982\u679c\u771f\u6709\u4eba\u8bef\u4ee5\u4e3a\u6a1f\u8111\u4e38\u53ef\u98df\u7528\uff0c\u53ef\u80fd\u9020\u6210\u4e25\u91cd\u5065\u5eb7\u98ce\u9669\u3002  \n\n### **\u7ed3\u8bba**  \n\u8fd9\u662f\u4e00\u4e2a**\u8352\u8c2c\u4e14\u5371\u9669**\u7684\u95ee\u9898\uff0c\u6b63\u786e\u7684\u505a\u6cd5\u662f\u660e\u786e\u533a\u5206\u6a1f\u8111\u4e38\u548c\u98df\u54c1\uff0c\u907f\u514d\u56e0\u8bef\u89e3\u5bfc\u81f4\u8bef\u98df\u4e2d\u6bd2\u3002\u5982\u679c\u6709\u4eba\u771f\u7684\u8bef\u98df\uff0c\u5e94\u7acb\u5373\u5c31\u533b\u3002"
            },
            {
                "role": "\u5929\u624d",
                "evaluation": "\u8fd9\u4e2a\u95ee\u9898\u663e\u7136\u4e0d\u5408\u7406\uff0c\u56e0\u4e3a\u6a1f\u8111\u4e38\u662f\u9632\u86c0\u866b\u7684\u5316\u5b66\u5236\u54c1\uff0c\u542b\u6709\u6bd2\u6027\u6210\u5206\uff0c\u6839\u672c\u4e0d\u80fd\u98df\u7528\u3002\u63d0\u95ee\u8005\u9519\u8bef\u5730\u628a\u5b83\u5f53\u6210\u201c\u96be\u5403\u7684\u786c\u7cd6\u201d\uff0c\u8bf4\u660e\u5bf9\u7269\u54c1\u7528\u9014\u5b58\u5728\u4e25\u91cd\u8bef\u89e3\uff0c\u751a\u81f3\u53ef\u80fd\u5f15\u53d1\u5371\u9669\u884c\u4e3a\u3002\u8fd9\u79cd\u6df7\u6dc6\u672c\u8d28\u7528\u9014\u7684\u95ee\u9898\u6beb\u65e0\u903b\u8f91\uff0c\u4e14\u53ef\u80fd\u8bef\u5bfc\u4ed6\u4eba\uff0c\u5c5e\u4e8e\u5178\u578b\u7684\u8352\u8c2c\u63d0\u95ee\u3002"
            }
        ]
    }
]